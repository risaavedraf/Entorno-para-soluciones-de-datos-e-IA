# =====================================================
# Variables de Entorno - Entorno de Soluciones de Datos e IA
# Copiar este archivo a .env y editar los valores
# NUNCA subir .env a GitHub
# =====================================================

# Docker / PostgreSQL
POSTGRES_DB=housing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DB_PORT=5432

# pgAdmin
PGADMIN_EMAIL=admin@housing.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Aplicacion (FastAPI)
# Para desarrollo LOCAL (Docker):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/housing_db

# Para RENDER (descomentar y usar la URL interna de Render):
# DATABASE_URL=postgresql://user:pass@host:5432/housing_db

# Puerto de la API
PORT=8000
